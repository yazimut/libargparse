{
    "env": {
        "projectDefines": [
            "ARGPARSE_EXPORTS"
        ],
        "projectIncludes": [
            "${workspaceFolder}/include"
        ]
    },
    "configurations": [
        {
            "name": "Linux (debug)",
            "includePath": [
                "${env:projectIncludes}"
            ],
            "defines": [
                "${env:projectDefines}",
                "DEBUG"
            ],
            "compilerPath": "/usr/bin/g++",
            "cStandard": "c17",
            "cppStandard": "c++17",
            "intelliSenseMode": "linux-gcc-x64"
        },
        {
            "name": "Linux (release)",
            "includePath": [
                "${env:projectIncludes}"
            ],
            "defines": [
                "${env:projectDefines}",
                "NDEBUG"
            ],
            "compilerPath": "/usr/bin/g++",
            "cStandard": "c17",
            "cppStandard": "c++17",
            "intelliSenseMode": "linux-gcc-x64"
        },
        {
            "name": "Windows (debug)",
            "includePath": [
                "${env:projectIncludes}"
            ],
            "defines": [
                "${env:projectDefines}",
                "DEBUG"
            ],
            "compilerPath": "${env:ProgramFiles}/mingw64/bin/g++.exe",
            "cStandard": "c17",
            "cppStandard": "c++17",
            "intelliSenseMode": "windows-gcc-x64"
        },
        {
            "name": "Windows (release)",
            "includePath": [
                "${env:projectIncludes}"
            ],
            "defines": [
                "${env:projectDefines}",
                "NDEBUG"
            ],
            "compilerPath": "${env:ProgramFiles}/mingw64/bin/g++.exe",
            "cStandard": "c17",
            "cppStandard": "c++17",
            "intelliSenseMode": "windows-gcc-x64"
        }
    ],
    "version": 4
}
